# 数据库类型：sqlite（默认）或 postgres
DB_TYPE=sqlite

# SQLite 模式（默认）
DB_PATH=/app/data/pumpkin.db

# PostgreSQL 模式（当 DB_TYPE=postgres 时生效）
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pumpkin_pro
DB_SSLMODE=disable

# 可选：数据库为空时导入策略种子文件
STRATEGY_SEED_PATH=seed/strategies.json

# 后端构建期 Go 依赖下载配置（服务器网络不稳定时可改成可达代理）
BACKEND_GOPROXY=https://proxy.golang.org|https://goproxy.cn|direct
BACKEND_GOSUMDB=sum.golang.org

# 镜像拉取参数（部署流程会按需覆盖）
IMAGE_REGISTRY=ccr.ccs.tencentyun.com
IMAGE_NAMESPACE=your-tcr-namespace
IMAGE_TAG=latest

# 前端公开访问域名，用于登录、重置密码等邮件深链
APP_PUBLIC_BASE_URL=https://wolongtrader.top

# 鉴权配置
AUTH_JWT_SECRET=dev-only-change-me
AUTH_ACCESS_TOKEN_TTL_MINUTES=1440
AUTH_REFRESH_TOKEN_TTL_HOURS=168

# 邮件发送配置
# 本地开发默认建议保留 mock，避免误发真实邮件
MAIL_PROVIDER=mock
MAIL_FROM_EMAIL=no-reply@wolongtrader.top
MAIL_FROM_NAME=卧龙 Trader
MAIL_TENCENT_SECRET_ID=
MAIL_TENCENT_SECRET_KEY=
MAIL_TENCENT_TOKEN=
MAIL_TENCENT_REGION=ap-hongkong
MAIL_TENCENT_ENDPOINT=https://ses.tencentcloudapi.com
MAIL_TENCENT_API_VERSION=2020-10-02
MAIL_TENCENT_API_ACTION=SendEmail
MAIL_TENCENT_LANGUAGE=zh-CN
MAIL_TENCENT_TEMPLATE_ID=
MAIL_MOCK_LOG_BODIES=true
MAIL_MOCK_FAIL_DELIVERY=false
MAIL_MOCK_CAPTURE_RECIPIENT=dev-null@local.invalid

# 密码找回配置
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_RATE_LIMIT_PER_IP=10
PASSWORD_RESET_RATE_LIMIT_PER_EMAIL=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MINUTES=60
PASSWORD_RESET_EMAIL_COOLDOWN_SECONDS=60

# AI 自然语言选股（可选，留空则禁用 AI 选股功能）
# 支持任何兼容 OpenAI Chat Completions API 的服务
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
